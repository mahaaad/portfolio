<!doctype html><html lang="en"><head><meta charset="utf-8"/><link rel="icon" href="images/icons/mrlogo.svg"><meta name="viewport" content="width=device-width,initial-scale=1"/><meta name="theme-color" content="#000000"/><meta name="description" content="Web site created using create-react-app"/><link rel="apple-touch-icon" href="logo192.png"/><link rel="manifest" href="manifest.json"/><title>Mahad Rehan | Developer</title><script defer="defer" src="static/js/main.ce511fe7.js"></script><link href="static/css/main.f67d946b.css" rel="stylesheet"><link href="static/css/custom-fixes.css" rel="stylesheet"></head><body><noscript>You need to enable JavaScript to run this app.</noscript><div id="root"></div>
<script>
// Add Window Controls to Info Section
(function() {
  function addWindowControls() {
    const infoSection = document.querySelector('.info');
    if (!infoSection) {
      // Retry if element not found yet
      setTimeout(addWindowControls, 100);
      return;
    }
    
    // Check if controls already exist
    if (infoSection.querySelector('.info-window-controls')) {
      return;
    }
    
    // Create controls container
    const controlsContainer = document.createElement('div');
    controlsContainer.className = 'info-window-controls';
    
    // Create close button
    const closeBtn = document.createElement('button');
    closeBtn.className = 'info-window-btn close';
    closeBtn.setAttribute('aria-label', 'Close window');
    closeBtn.title = 'Close';
    
    // Create minimize button
    const minimizeBtn = document.createElement('button');
    minimizeBtn.className = 'info-window-btn minimize';
    minimizeBtn.setAttribute('aria-label', 'Minimize window');
    minimizeBtn.title = 'Minimize';
    
    // Add buttons to container
    controlsContainer.appendChild(closeBtn);
    controlsContainer.appendChild(minimizeBtn);
    
    // Insert controls at the beginning of info section
    infoSection.insertBefore(controlsContainer, infoSection.firstChild);
    
    // Add click handlers (optional - for future functionality)
    closeBtn.addEventListener('click', function(e) {
      e.preventDefault();
      // Could add hide functionality here if desired
      console.log('Close clicked');
    });
    
    minimizeBtn.addEventListener('click', function(e) {
      e.preventDefault();
      // Could add minimize functionality here if desired
      console.log('Minimize clicked');
    });
  }
  
  // Use MutationObserver to watch for React app rendering
  const observer = new MutationObserver(function(mutations, obs) {
    const infoSection = document.querySelector('.info');
    if (infoSection) {
      addWindowControls();
      obs.disconnect(); // Stop observing once added
    }
  });
  
  // Start observing after DOM is ready
  function startObserving() {
    const root = document.getElementById('root');
    if (root) {
      observer.observe(root, {
        childList: true,
        subtree: true
      });
      // Also try immediately
      setTimeout(addWindowControls, 300);
    }
  }
  
  // Wait for React app to load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', startObserving);
  } else {
    startObserving();
  }
})();

// Add Dark Mode Toggle to Nav Bar
(function() {
  function addDarkModeToggle() {
    const navBar = document.querySelector('.nav-bar');
    if (!navBar) {
      // Retry if element not found yet
      setTimeout(addDarkModeToggle, 100);
      return;
    }
    
    // Check if toggle already exists
    if (navBar.querySelector('.dark-mode-toggle')) {
      return;
    }
    
    // Create toggle button
    const toggleButton = document.createElement('button');
    toggleButton.className = 'dark-mode-toggle';
    toggleButton.id = 'darkModeToggle';
    toggleButton.setAttribute('aria-label', 'Toggle dark mode');
    toggleButton.innerHTML = `
      <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2.25a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V3a.75.75 0 01.75-.75zM7.5 12a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM18.894 6.166a.75.75 0 00-1.06-1.06l-1.591 1.59a.75.75 0 101.06 1.061l1.591-1.59zM21.75 12a.75.75 0 01-.75.75h-2.25a.75.75 0 010-1.5H21a.75.75 0 01.75.75zM17.834 18.894a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 10-1.061 1.06l1.59 1.591zM12 18a.75.75 0 01.75.75V21a.75.75 0 01-1.5 0v-2.25A.75.75 0 0112 18zM7.758 17.303a.75.75 0 00-1.061-1.06l-1.591 1.59a.75.75 0 001.06 1.061l1.591-1.59zM6 12a.75.75 0 01-.75.75H3a.75.75 0 010-1.5h2.25A.75.75 0 016 12zM6.697 7.757a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 00-1.061 1.06l1.59 1.591z"/>
      </svg>
      <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
        <path fill-rule="evenodd" d="M9.528 1.718a.75.75 0 01.162.819A8.97 8.97 0 009 6a9 9 0 009 9 8.97 8.97 0 003.463-.69.75.75 0 01.981.98 10.503 10.503 0 01-9.694 6.46c-5.799 0-10.5-4.701-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 01.818.162z" clip-rule="evenodd"/>
      </svg>
    `;
    
    // Add button to nav bar (at the end, after all links)
    navBar.appendChild(toggleButton);
  }
  
  // Use MutationObserver to watch for React app rendering
  const observer = new MutationObserver(function(mutations, obs) {
    const navBar = document.querySelector('.nav-bar');
    if (navBar) {
      addDarkModeToggle();
      obs.disconnect(); // Stop observing once added
    }
  });
  
  // Start observing after DOM is ready
  function startObserving() {
    const root = document.getElementById('root');
    if (root) {
      observer.observe(root, {
        childList: true,
        subtree: true
      });
      // Also try immediately
      setTimeout(addDarkModeToggle, 300);
    }
  }
  
  // Wait for React app to load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', startObserving);
  } else {
    startObserving();
  }
})();

// Dark Mode Toggle Functionality
(function() {
  // Check for saved theme preference or default to light mode
  const savedTheme = localStorage.getItem('theme');
  const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
  
  // Apply theme on page load
  function applyTheme(isDark) {
    if (isDark) {
      document.documentElement.classList.add('dark-mode');
      document.body.classList.add('dark-mode');
      // Update theme-color meta tag
      const themeColorMeta = document.querySelector('meta[name="theme-color"]');
      if (themeColorMeta) {
        themeColorMeta.setAttribute('content', '#1a1a1a');
      }
    } else {
      document.documentElement.classList.remove('dark-mode');
      document.body.classList.remove('dark-mode');
      // Update theme-color meta tag
      const themeColorMeta = document.querySelector('meta[name="theme-color"]');
      if (themeColorMeta) {
        themeColorMeta.setAttribute('content', '#000000');
      }
    }
  }
  
  // Initialize theme
  if (savedTheme) {
    applyTheme(savedTheme === 'dark');
  } else if (prefersDark) {
    applyTheme(true);
    localStorage.setItem('theme', 'dark');
  } else {
    applyTheme(false);
    localStorage.setItem('theme', 'light');
  }
  
  // Toggle function
  function toggleDarkMode() {
    const isDark = document.body.classList.contains('dark-mode');
    applyTheme(!isDark);
    localStorage.setItem('theme', !isDark ? 'dark' : 'light');
  }
  
  // Add event listener to toggle button (with retry mechanism)
  function attachToggleListener() {
    const toggleButton = document.getElementById('darkModeToggle');
    if (toggleButton) {
      toggleButton.addEventListener('click', toggleDarkMode);
    } else {
      // Retry if button not found yet
      setTimeout(attachToggleListener, 100);
    }
  }
  
  // Wait for button to be added
  setTimeout(attachToggleListener, 500);
  
  // Listen for system theme changes
  if (window.matchMedia) {
    const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
    mediaQuery.addEventListener('change', (e) => {
      // Only auto-switch if user hasn't manually set a preference
      if (!localStorage.getItem('theme')) {
        applyTheme(e.matches);
        localStorage.setItem('theme', e.matches ? 'dark' : 'light');
      }
    });
  }
})();
</script></body></html>